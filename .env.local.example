# Copy this file to .env.local and fill in your real API keys.
# .env.local is gitignored — it will NEVER be committed to the repository.
#
# After filling in keys, run: bash build.sh
# Then open app/index.html in your browser to test locally.

GROQ_API_KEY=gsk_your_groq_key_here
OPENAI_API_KEY=sk-proj-your_openai_key_here
GEMINI_API_KEY=AIza_your_gemini_key_here
