{
  "appId": "ug.homatt.health",
  "appName": "Homatt Health",
  "webDir": "app",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.supabase.co",
      "fonts.googleapis.com",
      "fonts.gstatic.com",
      "cdn.jsdelivr.net"
    ]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1B5E20",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
